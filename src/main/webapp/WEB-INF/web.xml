<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">
	<display-name>Oceanview Hotel Reservation System</display-name>
	<servlet>
		<servlet-name>LoginServlet</servlet-name>
		<display-name>LoginServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.LoginServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>ReservationServlet</servlet-name>
		<display-name>ReservationServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.ReservationServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>BillServlet</servlet-name>
		<display-name>BillServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.BillServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>LogoutServlet</servlet-name>
		<display-name>LogoutServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.LogoutServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>UpdateReservationServlet</servlet-name>
		<display-name>UpdateReservationServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.UpdateReservationServlet</servlet-class>
	</servlet>
	<servlet>
		<servlet-name>DeleteReservationServlet</servlet-name>
		<display-name>DeleteReservationServlet</display-name>
		<description></description>
		<servlet-class>com.icbt.controller.DeleteReservationServlet</servlet-class>
	</servlet>
	<servlet-mapping>
		<servlet-name>LoginServlet</servlet-name>
		<url-pattern>/LoginServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>ReservationServlet</servlet-name>
		<url-pattern>/ReservationServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>BillServlet</servlet-name>
		<url-pattern>/BillServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>LogoutServlet</servlet-name>
		<url-pattern>/LogoutServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>UpdateReservationServlet</servlet-name>
		<url-pattern>/UpdateReservationServlet</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
		<servlet-name>DeleteReservationServlet</servlet-name>
		<url-pattern>/DeleteReservationServlet</url-pattern>
	</servlet-mapping>
</web-app>
